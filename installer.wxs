<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  DK-Lang Interpreter MSI Installer                        -->
  <!--  Features: PATH config, custom dir, upgrade detection      -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Product Id="*"
           Name="DK-Lang"
           Language="1033"
           Version="1.4.0"
           Manufacturer="DK-Lang Foundation"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">

    <Package InstallerVersion="300" Compressed="yes"
             InstallScope="perMachine"
             Description="DK-Lang (DeepSeek Knowledge Language) Interpreter"
             Comments="AI-Optimized Programming Language Runtime"
             Keywords="DK-Lang,DSKL,DeepSeek,Programming,Language" />

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  Upgrade detection                                    -->
    <!-- ══════════════════════════════════════════════════════ -->
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of DK-Lang is already installed." />

    <!-- Prevent downgrading -->
    <Upgrade Id="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
      <UpgradeVersion Minimum="1.4.0" OnlyDetect="yes"
                      Property="NEWERVERSIONDETECTED" />
      <UpgradeVersion Minimum="1.0.0" Maximum="1.4.0"
                      IncludeMinimum="yes" IncludeMaximum="no"
                      Property="OLDERVERSIONBEINGUPGRADED" />
    </Upgrade>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  Custom action for upgrade check                      -->
    <!-- ══════════════════════════════════════════════════════ -->
    <CustomAction Id="CheckExistingInstall"
                  Error="An existing DK-Lang installation was found. Please uninstall it first from Add/Remove Programs, or use the new installer to upgrade." />

    <InstallExecuteSequence>
      <Custom Action="CheckExistingInstall"
              After="FindRelatedProducts">
        NEWERVERSIONDETECTED AND NOT Installed
      </Custom>
      <RemoveExistingProducts After="InstallInitialize" />
    </InstallExecuteSequence>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  Media                                               -->
    <!-- ══════════════════════════════════════════════════════ -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  Properties                                          -->
    <!-- ══════════════════════════════════════════════════════ -->
    <Property Id="ARPHELPLINK" Value="https://github.com/dk-lang" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/dk-lang" />
    <Property Id="ARPCONTACT" Value="DK-Lang Foundation" />
    <Property Id="ARPCOMMENTS" Value="AI-Optimized Programming Language" />
    <Property Id="ALLUSERS" Value="1" />

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  UI: WixUI_InstallDir (browse folder dialog)          -->
    <!-- ══════════════════════════════════════════════════════ -->
    <UIRef Id="WixUI_InstallDir" />
    <UIRef Id="WixUI_ErrorProgressText" />

    <!-- Install directory property -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <!-- Default install path -->
    <SetProperty Id="INSTALLFOLDER"
                 Value="[ProgramFiles64Folder]DK-Lang"
                 After="CostFinalize" />

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  Custom dialog for PATH environment variable           -->
    <!-- ══════════════════════════════════════════════════════ -->
    <Property Id="ADDTOPATH" Value="1" Secure="yes" />

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  Features                                            -->
    <!-- ══════════════════════════════════════════════════════ -->
    <Feature Id="MainFeature" Title="DK-Lang Interpreter"
             Description="DK-Lang runtime and standard library"
             Level="1" Display="expand"
             ConfigurableDirectory="INSTALLFOLDER"
             AllowAdvertise="no" Absent="disallow">
      <ComponentGroupRef Id="CoreComponents" />
      <Feature Id="PathFeature" Title="Add to PATH"
               Description="Add DK-Lang to the system PATH environment variable"
               Level="1" AllowAdvertise="no">
        <ComponentRef Id="EnvPathComponent" />
      </Feature>
      <Feature Id="ExamplesFeature" Title="Examples"
               Description="Install example DK-Lang programs"
               Level="2" AllowAdvertise="no">
        <ComponentGroupRef Id="ExampleComponents" />
      </Feature>
    </Feature>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  Directory Structure                                  -->
    <!-- ══════════════════════════════════════════════════════ -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="DK-Lang">

          <!-- Main executable -->
          <Component Id="MainExe" Guid="*" Win64="yes">
            <File Id="dk.exe" Name="dk.exe"
                  Source="dist\dk-lang-clean\dk.exe"
                  KeyPath="yes" />
            <File Id="python311.dll" Name="python311.dll"
                  Source="dist\dk-lang-clean\python311.dll" />
            <File Id="frozen_license" Name="frozen_application_license.txt"
                  Source="dist\dk-lang-clean\frozen_application_license.txt" />
          </Component>

          <!-- Lib directory -->
          <Directory Id="LibDir" Name="lib">
            <Component Id="LibFiles" Guid="*" Win64="yes">
              <File Id="library_dat" Name="library.dat"
                    Source="dist\dk-lang-clean\lib\library.dat" />
              <File Id="library_zip" Name="library.zip"
                    Source="dist\dk-lang-clean\lib\library.zip" />
              <File Id="sqlite3_dll" Name="sqlite3.dll"
                    Source="dist\dk-lang-clean\lib\sqlite3.dll" />
              <File Id="libcrypto_dll" Name="libcrypto-3.dll"
                    Source="dist\dk-lang-clean\lib\libcrypto-3.dll" />
              <File Id="libssl_dll" Name="libssl-3.dll"
                    Source="dist\dk-lang-clean\lib\libssl-3.dll" />
              <File Id="libffi_dll" Name="libffi-8.dll"
                    Source="dist\dk-lang-clean\lib\libffi-8.dll" />
            </Component>

            <!-- dklang Python module -->
            <Directory Id="DklangDir" Name="dklang">
              <Component Id="DklangPycs" Guid="*" Win64="yes">
                <File Id="dklang_init" Name="__init__.pyc"
                      Source="dist\dk-lang-clean\lib\dklang\__init__.pyc" />
                <File Id="dklang_ast" Name="ast_nodes.pyc"
                      Source="dist\dk-lang-clean\lib\dklang\ast_nodes.pyc" />
                <File Id="dklang_lexer" Name="lexer.pyc"
                      Source="dist\dk-lang-clean\lib\dklang\lexer.pyc" />
                <File Id="dklang_parser" Name="parser.pyc"
                      Source="dist\dk-lang-clean\lib\dklang\parser.pyc" />
                <File Id="dklang_interp" Name="interpreter.pyc"
                      Source="dist\dk-lang-clean\lib\dklang\interpreter.pyc" />
                <File Id="dklang_db" Name="database.pyc"
                      Source="dist\dk-lang-clean\lib\dklang\database.pyc" />
                <File Id="dklang_httpd" Name="httpd.pyc"
                      Source="dist\dk-lang-clean\lib\dklang\httpd.pyc" />
                <File Id="dklang_ext" Name="extensions.pyc"
                      Source="dist\dk-lang-clean\lib\dklang\extensions.pyc" />
              </Component>
              <Directory Id="FfiDir" Name="ffi">
                <Component Id="FfiFiles" Guid="*" Win64="yes">
                  <File Id="ffi_init" Name="__init__.pyc"
                        Source="dist\dk-lang-clean\lib\dklang\ffi\__init__.pyc" />
                </Component>
              </Directory>
            </Directory>
          </Directory>

          <!-- Documentation -->
          <Directory Id="DocDir" Name="doc">
            <Component Id="DocFiles" Guid="*" Win64="yes">
              <File Id="doc_dev" Name="DEVELOPER.md"
                    Source="dist\dk-lang-clean\doc\DEVELOPER.md" />
              <File Id="doc_spec" Name="DK-LANG-SPEC.md"
                    Source="dist\dk-lang-clean\doc\DK-LANG-SPEC.md" />
            </Component>
          </Directory>

        </Directory>
      </Directory>

      <!-- Start Menu -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="StartMenuDir" Name="DK-Lang">
          <Component Id="StartMenuShortcuts" Guid="*">
            <Shortcut Id="DkDocShortcut" Name="DK-Lang Documentation"
                      Target="[INSTALLFOLDER]doc\DK-LANG-SPEC.md" />
            <Shortcut Id="UninstallShortcut" Name="Uninstall DK-Lang"
                      Target="[SystemFolder]msiexec.exe"
                      Arguments="/x [ProductCode]" />
            <RemoveFolder Id="RemoveStartMenu" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\DK-Lang\Interpreter"
                          Name="StartMenu" Type="string" Value="1"
                          KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>

      <!-- Desktop -->
      <Directory Id="DesktopFolder" />
    </Directory>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  PATH Environment Variable                            -->
    <!-- ══════════════════════════════════════════════════════ -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="EnvPathComponent" Guid="*" Win64="yes">
        <CreateFolder />
        <Environment Id="PATH" Name="PATH" Value="[INSTALLFOLDER]"
                     Permanent="no" Part="last" Action="set"
                     System="yes" />
        <RegistryValue Root="HKLM"
                       Key="Software\DK-Lang\Interpreter"
                       Name="InstallPath" Type="string"
                       Value="[INSTALLFOLDER]" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  Component Groups                                     -->
    <!-- ══════════════════════════════════════════════════════ -->
    <ComponentGroup Id="CoreComponents">
      <ComponentRef Id="MainExe" />
      <ComponentRef Id="LibFiles" />
      <ComponentRef Id="DklangPycs" />
      <ComponentRef Id="FfiFiles" />
      <ComponentRef Id="DocFiles" />
      <ComponentRef Id="StartMenuShortcuts" />
    </ComponentGroup>

    <ComponentGroup Id="ExampleComponents" />

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  UI Sequence (progress bar is built-in)                -->
    <!-- ══════════════════════════════════════════════════════ -->
    <UI>
      <ProgressText Action="InstallFiles">Installing DK-Lang files...</ProgressText>
      <ProgressText Action="InstallExecute">Configuring DK-Lang...</ProgressText>
      <ProgressText Action="CreateShortcuts">Creating shortcuts...</ProgressText>
      <ProgressText Action="WriteRegistryValues">Writing registry...</ProgressText>
    </UI>

  </Product>
</Wix>
